# MoltStreamer — copy to .env and fill in

# --- Gradient Bang ----------------------------------------------------------
# Sign up at gradient-bang.com first.
GB_ENV=prod
GB_API_BASE_PROD=https://api.gradient-bang.com/functions/v1
GB_API_BASE_LOCAL=http://127.0.0.1:54321/functions/v1
GB_EMAIL=
GB_PASSWORD=
GB_CHARACTER=MoltStreamer
GB_LOG_DAILY_JOIN_URL=false
GB_TASK_PROMPT_PATH=./prompts/streamer_task.md

# --- Daily (for AUDIENCE room; game room is created by GB) -----------------
DAILY_API_KEY=
DAILY_DOMAIN=

# --- NVIDIA Nemotron LLM (vLLM, OpenAI-compatible) --------------------------
# Endpoint provided on hackathon day. Falls back to bot-gpt.py path if empty.
NEMOTRON_LLM_URL=
NEMOTRON_LLM_API_KEY=EMPTY
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_ENABLE_THINKING=false

# --- NVIDIA Nemotron Speech Streaming STT (audience voice in, P3 only) ------
NVIDIA_ASR_URL=

# --- Gradium TTS (Officer voice out) ----------------------------------------
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# --- OpenAI (direct; only used if NEMOTRON_LLM_URL + OPENROUTER_API_KEY are unset) -
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# --- OpenRouter (open-weights routing; takes priority over OPENAI_API_KEY) -
# Get a key at openrouter.ai. Models: meta-llama/llama-3.3-70b-instruct,
# qwen/qwen-2.5-72b-instruct, anthropic/claude-3.5-sonnet, etc.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- AWS (Bedrock Titan v2 embeddings + Claude Haiku failure tagger; S3) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_TAGGER_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0
S3_BUCKET=moltstreamer-artifacts

# --- Cekura (auto-improvement loop) -----------------------------------------
CEKURA_API_KEY=
CEKURA_BASE_URL=https://api.cekura.ai
# Live per-beat eval loop (B). 30s windows, scored by Cekura, failures tagged
# (Haiku) + embedded (Titan) + stored in FAISS for retrieval next turn.
BEAT_TICKER_ENABLED=true
BEAT_INTERVAL_SECONDS=30
# Read side: pulls top-k past failures and prepends them to each LLM turn.
# Toggle off to demo "before" version that doesn't learn between beats.
FAILURE_RETRIEVAL_ENABLED=true
# Post-session full-call dump to Cekura's observability provider (C).
CEKURA_OBSERVABILITY_ENABLED=true

# --- App --------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
SQLITE_PATH=./data/moltstreamer.db
FAISS_PATH=./data/failures.faiss
LOG_LEVEL=INFO
